# Wize Guyz Grille — Environment Variables
# Copy this file to .env.local and fill in your values.

# ─── Mailchimp ────────────────────────────────────────────────────────────────
# Found in: Mailchimp → Account → Extras → API keys
MAILCHIMP_API_KEY=your-api-key-here-us21

# Found in: Mailchimp → Audience → Settings → Audience name and defaults → Audience ID
MAILCHIMP_LIST_ID=your-list-id-here

# The datacenter suffix from your API key (e.g. if key ends in "-us21", use "us21")
MAILCHIMP_SERVER_PREFIX=us21

# ─── Club Signup (optional — used for direct Mailchimp form fallback) ─────────
# Found in: Mailchimp → Audience → Signup forms → Embedded forms → Form action URL
NEXT_PUBLIC_MAILCHIMP_CLUB_URL=https://YOURACCOUNTID.us1.list-manage.com/subscribe/post?u=XXXXXXXX&id=XXXXXXXX
